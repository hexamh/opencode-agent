# Environment variables for local development
# Copy this file to .dev.vars and fill in your actual values
# Never commit .dev.vars to version control!

# Cloudflare AI Gateway (Required - Unified Billing)
# No provider API keys needed! All models available through AI Gateway
# Get these values from: https://dash.cloudflare.com/[account-id]/ai/ai-gateway
CLOUDFLARE_ACCOUNT_ID=7416e7b5d307baabca87e8fba69158e5
CLOUDFLARE_GATEWAY_ID=your-gateway-id
CLOUDFLARE_API_TOKEN=your-api-token

# Telegram Bot (Optional)
# Create a bot: https://t.me/BotFather
# Send /newbot and follow instructions
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_WEBHOOK_SECRET=your-random-secret-string
